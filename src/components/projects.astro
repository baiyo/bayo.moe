---
const projects = [
    {
        name: "my portfolio",
        desc: "this very site you're looking at.",
        href: "https://github.com/baiyo",
        icon: "https://avatars.githubusercontent.com/u/119372694?v=4&size=64"
    },
    {
        name: "cool game thing",
        desc: "a lua project i've been working on.",
        href: "https://github.com/baiyo/project",
        icon: "/icons/game.png"
    },
]
---

<section>
  <h2>Projects</h2>
  <div class="grid">
    {projects.map(p => (
      <a href={p.href} target="_blank" class="card">
        <div class="card-top">
          <div class="card-title">
            {p.icon && <img src={p.icon} alt="" width="20" height="20" />}
            <span>{p.name}</span>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </div>
        <p class="card-desc">{p.desc}</p>
      </a>
    ))}
  </div>
</section>

<style>
    section {
        margin-bottom: 2rem;
    }

    h2 {
        font-size: 1.1rem;
        margin-bottom: 0.75rem;
    }

    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
    }

    .card {
        background: var(--secondary-bg);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        padding: 0.75rem 1rem;
        text-decoration: none;
        color: var(--color-text);
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        transition: border-color 0.2s ease, background 0.2s ease, transform 0.3s ease;
    }

    .card:hover {
        border-color: var(--color-puh);
        text-decoration: none;
        transform: translateY(-3px);
    }

    .card-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .card-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 14px;
        font-weight: 600;
    }

    .card-title img {
        border-radius: 4px;
    }

    .card-desc {
        font-size: 13px;
        color: var(--color-text-muted);
        line-height: 1.5;
    }

    svg {
        flex-shrink: 0;
        opacity: 0.5;
    }

    @media (max-width: 500px) {
        .grid { grid-template-columns: 1fr; }
    }
</style>